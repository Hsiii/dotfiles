" UI
set number
set cursorline
set showmatch
set signcolumn=yes
set laststatus=2
set statusline=%f\ %m%r%h%w%=%y\ %{&fileencoding?&fileencoding:&encoding}\ [%l:%c]\ %p%%
set showcmd
set wildmenu
set wildmode=longest:full,full

" Theme
syntax on
set termguicolors
colorscheme rosepine_moon

" Editing
set mouse=a
set completeopt=menuone,noselect
set backspace=indent,eol,start
set whichwrap+=<,>,h,l,[,]
set virtualedit=block
set clipboard=unnamedplus

" Indentation
set noexpandtab
set tabstop=4
set shiftwidth=4
set softtabstop=0
set autoindent
filetype plugin indent on

" Windows and buffers
set splitright
set splitbelow
set hidden
set confirm
set autoread

" Files and state
set undofile
set undodir=~/.local/state/vim/undo
set backupdir=~/.local/state/vim/backup//
set directory=~/.local/state/vim/swap//

" Search
set ignorecase
set smartcase
set incsearch
set hlsearch

" Display
set linebreak
set breakindent
set scrolloff=8
set sidescrolloff=8

" Plugins
let g:move_map_keys = 0
set updatetime=100

" Mappings
nmap <A-Down> <Plug>MoveLineDown
nmap <A-Up> <Plug>MoveLineUp
xmap <A-Down> <Plug>MoveBlockDown
xmap <A-Up> <Plug>MoveBlockUp
imap <A-Down> <Esc><Plug>MoveLineDowngi
imap <A-Up> <Esc><Plug>MoveLineUpgi

nnoremap <C-s> :write<CR>
inoremap <C-s> <Esc>:write<CR>gi
xnoremap <C-s> <Esc>:write<CR>gv
