" Show absolute line numbers in the left gutter.
set number

" Enable mouse support for cursor movement, selection, scrolling, and splits.
set mouse=a

" Highlight the current cursor line for easier navigation.
set cursorline

" Always show the status line for editor and file context.
set laststatus=2

" Improve command-line completion for files, buffers, commands, and options.
set wildmenu
set wildmode=longest:full,full

" Open new splits in the same direction as modern editor panes.
set splitright
set splitbelow

" Use the system clipboard for yank, delete, change, and paste operations.
set clipboard=unnamedplus

" Keep undo history across Vim sessions outside the dotfiles repository.
set undofile
set undodir=~/.local/state/vim/undo

" Make search interactive, highlighted, and smart about casing.
set ignorecase
set smartcase
set incsearch
set hlsearch

" Wrap long visual lines at word boundaries and preserve indentation.
set linebreak
set breakindent

" Use real tab characters and display each tab as four columns.
set noexpandtab
set tabstop=4
set shiftwidth=4
set softtabstop=0

" Continue the previous line's indentation on new lines.
set autoindent

" Load filetype-specific plugins and indentation rules.
filetype plugin indent on

" Use vim-move for VS Code-style line and selection movement.
let g:move_map_keys = 0
nmap <A-Down> <Plug>MoveLineDown
nmap <A-Up> <Plug>MoveLineUp
xmap <A-Down> <Plug>MoveBlockDown
xmap <A-Up> <Plug>MoveBlockUp

" Enable syntax highlighting and true-color terminal themes.
syntax on
set termguicolors
colorscheme rosepine_moon
